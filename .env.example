# Copy to .env and fill in. All keys are OPTIONAL — the app degrades gracefully.

# Port for the local web server
PORT=8080

# --- Aircraft: authoritative military feed (ADSB-Exchange via RapidAPI) ---
# If set, this is used INSTEAD of the OpenSky heuristic — every returned
# aircraft is genuinely military-tagged. Subscribe at:
# https://rapidapi.com/adsbx/api/adsbexchange-com1
ADSBX_API_KEY=

# --- Aircraft: fallback feed (OpenSky Network) ---
# Used when ADSBX_API_KEY is empty. Anonymous works but is rate-limited
# (~once / 10s). For higher limits, register a free OAuth2 client at
# https://opensky-network.org and paste the client credentials here.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Ships (aisstream.io) ---
# Free API key from https://aisstream.io  (no key = ships layer disabled)
AISSTREAM_API_KEY=
